# Event Operations Platform - Environment Variables Template
# Copy this file to .env and update values as needed

# Database Configuration
POSTGRES_USER=events_user
POSTGRES_PASSWORD=events_pass
POSTGRES_DB=events_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://events_user:events_pass@localhost:5432/events_db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Application Settings
APP_NAME="Event Operations Platform"
APP_VERSION=0.1.0
DEBUG=false

# Security
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (comma-separated or JSON array)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Backend URL
BACKEND_URL=http://localhost:8000

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Deployment
ENVIRONMENT=development
